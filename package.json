{
  "name": "llmproxy",
  "version": "0.1.0",
  "description": "OpenAI-compatible proxy and load balancer for local LLM backends.",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "build:server": "tsc -p tsconfig.json",
    "build:dashboard": "node ./scripts/build-dashboard-client.cjs",
    "build": "npm run build:server && npm run build:dashboard",
    "dev": "node ./scripts/dev-with-dashboard.cjs",
    "start": "npm run build && node dist/index.js",
    "start:dashboard": "node ./scripts/start-with-dashboard.cjs",
    "test": "node ./scripts/run-tests.cjs",
    "test:memory": "npm run build && node --expose-gc ./scripts/memory-soak.cjs",
    "test:chaos-memory": "npm run build && node --expose-gc ./scripts/chaos-memory-soak.cjs",
    "test:streams-500": "npm run build:server && node --expose-gc ./scripts/chaos-memory-soak.cjs --mode=active-streams --connections=500 --min-tokens=1000 --max-tokens=40000",
    "test:streams-500:dashboard": "npm run build:server && node --expose-gc ./scripts/chaos-memory-soak.cjs --mode=active-streams --connections=500 --min-tokens=1000 --max-tokens=40000 --proxy-port=4311 --hold-open"
  },
  "engines": {
    "node": ">=18.17.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.13.14",
    "@vitejs/plugin-vue": "^6.0.5",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.5.3",
    "vite": "^8.0.0",
    "vue": "^3.5.30",
    "vue-tsc": "^3.2.5"
  },
  "dependencies": {
    "ace-builds": "^1.43.6",
    "ajv": "^8.18.0",
    "markdown-it": "^14.1.1",
    "vue-router": "^4.6.4"
  }
}
